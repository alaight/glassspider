NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: set to laightworks.com so hub sign-in cookies are visible on *.laightworks.com (must match the hub app).
# SUPABASE_AUTH_COOKIE_DOMAIN=laightworks.com

NEXT_PUBLIC_LAIGHTWORKS_LOGIN_URL=https://laightworks.com/login
GLASSSPIDER_PROJECT_SLUG=glassspider
GLASSSPIDER_ADMIN_ROLES=owner,admin

# Optional: Explore rendered/api diagnostics proxy to worker debug endpoint (server-side only).
GLASSSPIDER_WORKER_INTERNAL_URL=
GLASSSPIDER_WORKER_SECRET=
